{
  "mcpServers": {
    "playwright-local": {
      "command": "npx",
      "env": {
        "npm_config_cache": ".mcp-cache/npm",
        "PLAYWRIGHT_BROWSERS_PATH": ".mcp-cache/ms-playwright"
      },
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--allowed-hosts",
        "localhost,127.0.0.1",
        "--allowed-origins",
        "https://127.0.0.1;https://localhost;http://127.0.0.1:8025;http://localhost:8025;http://localhost:5173;http://127.0.0.1:5173;http://localhost:5174;http://127.0.0.1:5174;http://localhost:5175;http://127.0.0.1:5175",
        "--block-service-workers",
        "--ignore-https-errors",
        "--headless"
      ]
    },
    "sqlite-readonly": {
      "command": "uv",
      "args": [
        "run",
        "--python",
        "3.14",
        "--with",
        "mcp",
        "python",
        "script/mcp/sqlite_readonly_server.py"
      ],
      "env": {
        "SQLITE_DB_PATH": "app/database/app.db",
        "UV_CACHE_DIR": ".mcp-cache/uv"
      }
    }
  }
}
