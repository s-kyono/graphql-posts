{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    "typescript/no-extraneous-class": [
      "error",
      {
        "allowWithDecorator": true
      }
    ]
  },
  "env": {
    "builtin": true
  }
}
