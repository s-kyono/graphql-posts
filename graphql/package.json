{
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@pothos/core": "^4.12.0",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "graphql": "^16.14.1",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.8",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-resolvers": "^6.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
